# Lian Li USB device permissions
# Install to: /etc/udev/rules.d/99-lianli.rules
# Reload with: sudo udevadm control --reload-rules && sudo udevadm trigger

# Wireless TX dongle
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="8040", MODE="0666"
# Wireless RX dongle
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="8041", MODE="0666"

# Strimer Plus LED strip
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a200", MODE="0666"

# ENE 6K77 SL/AL fan controllers
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a100", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a101", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a102", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a103", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a104", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a105", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a106", MODE="0666"

# TL Fan controller
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7372", MODE="0666"
# TLLCD
SUBSYSTEM=="usb", ATTR{idVendor}=="04fc", ATTR{idProduct}=="7393", MODE="0666"

# Galahad II Trinity AIO
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7371", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7373", MODE="0666"

# HydroShift LCD AIO
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7398", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7399", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="739a", MODE="0666"

# Galahad II LCD / Vision AIO
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7391", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7395", MODE="0666"

# SLV3 wireless LCD fan
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="0005", MODE="0666"
# TLV2 wireless LCD fan
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="0006", MODE="0666"
# HydroShift II LCD Circle
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="a021", MODE="0666"
# HydroShift II LCD Square (H2S)
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="a034", MODE="0666"
# Lancool 207 Digital
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="a065", MODE="0666"
# Universal Screen 8.8"
SUBSYSTEM=="usb", ATTR{idVendor}=="1cbe", ATTR{idProduct}=="a088", MODE="0666"

# Display mode switchers
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="7523", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="acd1", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="ace1", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="ad11", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="ad20", MODE="0666"
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="ad21", MODE="0666"

# --- Force usbhid to bind HID devices the kernel may not claim automatically ---
# Some devices have HID interfaces that usbhid doesn't recognise, so no
# /dev/hidraw node is created. Registering VID:PID via new_id fixes this.

# HydroShift LCD AIO
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7398", RUN+="/bin/sh -c 'echo 0416 7398 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7399", RUN+="/bin/sh -c 'echo 0416 7399 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="739a", RUN+="/bin/sh -c 'echo 0416 739a > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# Galahad II LCD / Vision AIO
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7391", RUN+="/bin/sh -c 'echo 0416 7391 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7395", RUN+="/bin/sh -c 'echo 0416 7395 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# Strimer Plus LED strip
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a200", RUN+="/bin/sh -c 'echo 0cf2 a200 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# ENE 6K77 SL/AL fan controllers
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a100", RUN+="/bin/sh -c 'echo 0cf2 a100 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a101", RUN+="/bin/sh -c 'echo 0cf2 a101 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a102", RUN+="/bin/sh -c 'echo 0cf2 a102 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a103", RUN+="/bin/sh -c 'echo 0cf2 a103 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a104", RUN+="/bin/sh -c 'echo 0cf2 a104 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a105", RUN+="/bin/sh -c 'echo 0cf2 a105 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a106", RUN+="/bin/sh -c 'echo 0cf2 a106 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# --- hidraw permissions for HID devices accessed via hidapi ---
# (hidraw nodes need ATTRS with S, matching parent USB device attributes)

# TL Fan controller
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0416", ATTRS{idProduct}=="7372", MODE="0666"

# Galahad II Trinity AIO
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0416", ATTRS{idProduct}=="7371", MODE="0666"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0416", ATTRS{idProduct}=="7373", MODE="0666"

# HydroShift LCD AIO
