// `max-pct` of -1 means "open-ended" (the final range with `max: None` in Rust).
export struct EditorRange {
    max-pct: int,
    color-r: int,
    color-g: int,
    color-b: int,
    color-a: int,
}

export struct EditorWidget {
    id: string,
    kind: string,
    kind-label: string,        // friendly display name
    x: float,
    y: float,
    width: float,
    height: float,
    rotation: float,
    visible: bool,
    update-interval-ms: int,

    text: string,
    font-name: string,
    font-size: float,
    color-r: int,
    color-g: int,
    color-b: int,
    color-a: int,
    align: string,

    format: string,
    unit: string,

    source-index: int,
    command: string,
    value-min: float,
    value-max: float,

    start-angle: float,
    sweep-angle: float,
    ring-thickness-pct: int,

    bg-r: int,
    bg-g: int,
    bg-b: int,
    bg-a: int,
    tick-count: int,

    corner-radius: int,
    bg-corner-radius: int,
    value-corner-radius: int,
    letter-spacing: int,

    show-gauge: bool,
    show-needle: bool,
    needle-width: float,
    needle-length-pct: int,
    needle-color-r: int,
    needle-color-g: int,
    needle-color-b: int,
    needle-color-a: int,
    tick-color-r: int,
    tick-color-g: int,
    tick-color-b: int,
    tick-color-a: int,
    needle-border-r: int,
    needle-border-g: int,
    needle-border-b: int,
    needle-border-a: int,
    needle-border-width: float,

    show-labels: bool,

    clock-show-seconds: bool,
    clock-show-hour-ticks: bool,
    clock-show-minor-ticks: bool,
    clock-show-numbers: bool,
    clock-second-hand-r: int,
    clock-second-hand-g: int,
    clock-second-hand-b: int,
    clock-second-hand-a: int,
    clock-minor-tick-r: int,
    clock-minor-tick-g: int,
    clock-minor-tick-b: int,
    clock-minor-tick-a: int,
    clock-hub-r: int,
    clock-hub-g: int,
    clock-hub-b: int,
    clock-hub-a: int,
    clock-hour-hand-width: int,
    clock-minute-hand-width: int,
    clock-second-hand-width: int,
    clock-hour-length-pct: int,
    clock-minute-length-pct: int,
    clock-second-length-pct: int,
    clock-hour-tick-length-pct: int,
    clock-minor-tick-length-pct: int,
    clock-hour-tick-width: int,
    clock-minor-tick-width: int,
    clock-hub-radius: int,

    image-path: string,
    opacity: float,
    fps: float,

    sparkline-history: int,
    sparkline-line-width: float,
    sparkline-auto-range: bool,
    sparkline-line-r: int,
    sparkline-line-g: int,
    sparkline-line-b: int,
    sparkline-line-a: int,
    sparkline-fill-r: int,
    sparkline-fill-g: int,
    sparkline-fill-b: int,
    sparkline-fill-a: int,
    sparkline-border-r: int,
    sparkline-border-g: int,
    sparkline-border-b: int,
    sparkline-border-a: int,
    sparkline-border-width: float,
    sparkline-corner-radius: int,
    sparkline-padding: int,
    sparkline-show-points: bool,
    sparkline-point-radius: float,
    sparkline-show-baseline: bool,
    sparkline-baseline-value: float,
    sparkline-baseline-r: int,
    sparkline-baseline-g: int,
    sparkline-baseline-b: int,
    sparkline-baseline-a: int,
    sparkline-baseline-width: float,
    sparkline-smooth: bool,
    sparkline-rtl: bool,
    sparkline-fill-from-ranges: bool,
    sparkline-range-blend: bool,
    sparkline-show-gridlines: bool,
    sparkline-gridlines-h: int,
    sparkline-gridlines-v: int,
    sparkline-gridline-r: int,
    sparkline-gridline-g: int,
    sparkline-gridline-b: int,
    sparkline-gridline-a: int,
    sparkline-gridline-width: float,
    sparkline-show-axis-labels: bool,
    sparkline-axis-label-count: int,
    sparkline-axis-labels-on-right: bool,
    sparkline-axis-label-format: string,
    sparkline-axis-font-name: string,
