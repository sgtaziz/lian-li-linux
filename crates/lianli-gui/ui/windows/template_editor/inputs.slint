    }
}

export component LabeledCheckBox inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    callback toggled(bool);

    height: 28px;

    changed checked => { box.checked = root.checked; }

    HorizontalLayout {
        alignment: start;
        box := CheckBox {
            text: root.text;
            checked: root.checked;
            toggled => { root.toggled(self.checked); }
        }
    }
}

export component RgbaRow inherits VerticalLayout {
    in property <string> title;
    in property <int> r;
    in property <int> g;
    in property <int> b;
    in property <int> a;
    callback edited(string, int);

    spacing: 4px;

    Text { text: root.title; font-size: 10px; color: Theme.text-secondary; }
    HorizontalLayout {
        spacing: 4px;
        BareSpinBox { value: root.r; edited(v) => { root.edited("r", v); } }
        BareSpinBox { value: root.g; edited(v) => { root.edited("g", v); } }
        BareSpinBox { value: root.b; edited(v) => { root.edited("b", v); } }
        BareSpinBox { value: root.a; edited(v) => { root.edited("a", v); } }
    }
}
