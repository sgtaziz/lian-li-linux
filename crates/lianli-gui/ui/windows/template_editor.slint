import { Theme } from "../theme.slint";
import {
    Button, ComboBox, LineEdit, ScrollView, Palette,
} from "std-widgets.slint";
import { EditorRange, EditorWidget } from "template_editor/types.slint";
import { BareSpinBox, LabeledCheckBox } from "template_editor/inputs.slint";
import { WidgetListRow } from "template_editor/list_row.slint";
import { WidgetBox } from "template_editor/canvas_box.slint";
import { PropertiesPanel } from "template_editor/props.slint";

export { EditorRange, EditorWidget }

export component TemplateEditorWindow inherits Window {
    title: "LCD Template Editor";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 900px;
    min-height: 540px;
    background: Palette.background;
    icon: @image-url("../../../../assets/icons/icon.png");

    in-out property <string> template-id: "";
    in-out property <string> template-name: "Untitled";
    in-out property <int> base-width: 480;
    in-out property <int> base-height: 480;
    in-out property <bool> rotated: false;
    in-out property <string> bg-type: "color";
    in-out property <int> bg-r: 0;
    in-out property <int> bg-g: 0;
    in-out property <int> bg-b: 0;
    in-out property <string> bg-image-path: "";

    in-out property <string> status-message: "";
    in-out property <bool> status-is-error: false;

    in-out property <[EditorWidget]> widgets: [];
    in-out property <int> selected-index: -1;
    in-out property <EditorWidget> selected-widget;
    in-out property <[EditorRange]> selected-ranges: [];

    in property <image> preview-image;
    in property <[string]> device-presets: [];
    in property <string> current-preset-label: "";
    in property <[string]> sensor-options: [];
    in property <[string]> widget-kinds: [
        "label", "value_text", "radial_gauge", "vertical_bar",
        "horizontal_bar", "speedometer", "core_bars", "sparkline", "image",
        "video", "clock_digital", "clock_analog",
    ];
    in property <[string]> widget-kind-labels: [
        "Label", "Sensor Value", "Radial Gauge", "Vertical Bar",
        "Horizontal Bar", "Speedometer", "Core Usage", "Sparkline", "Image",
        "Video", "Clock (Digital)", "Clock (Analog)",
    ];
    in property <[string]> font-names: [];
    in property <[string]> align-options: ["left", "center", "right"];

    callback save-requested();
    callback cancel();
    callback closed();
    callback copy-json-requested();

    callback header-field(string, string);
    callback widget-moved(int, float, float);
    callback widget-added(string);
    callback widget-removed(int);
    callback widget-reorder(int, int);
    // `field == "_select"` is a no-op edit that just sets the selection.
    callback widget-field(int, string, string);
    callback range-field(int, string, string);
    callback range-added();
    callback range-removed(int);
    callback pick-bg-image();
    callback pick-widget-image(int);
    callback preset-selected(string);
    callback request-preview();

    changed current-preset-label => { device-combo.current-value = root.current-preset-label; }

    VerticalLayout {
        Rectangle {
            height: 64px;
            background: Theme.card-background;
            border-width: 0px;
            border-color: Theme.border;

            HorizontalLayout {
                padding: 10px;
                spacing: 12px;

                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: "Template Name"; font-size: 10px; color: Theme.text-secondary; }
                    LineEdit {
                        width: 180px;
                        height: 28px;
                        text: root.template-name;
                        edited(v) => { root.header-field("name", v); }
                    }
                }

                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: "Target Device"; font-size: 10px; color: Theme.text-secondary; }
                    device-combo := ComboBox {
                        horizontal-stretch: 1;
                        min-width: 300px;
                        height: 28px;
                        model: root.device-presets;
                        current-value: root.current-preset-label;
                        selected(v) => { root.preset-selected(v); }
                    }
                }

                if root.base-width != root.base-height: VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: " "; font-size: 10px; }
                    LabeledCheckBox {
                        text: "Rotated";
                        checked: root.rotated;
                        toggled(c) => { root.header-field("rotated", c ? "true" : "false"); }
                    }
                }

                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: "Background"; font-size: 10px; color: Theme.text-secondary; }
                    HorizontalLayout {
                        spacing: 4px;
                        Button {
                            text: "Color";
                            height: 28px;
                            primary: root.bg-type == "color";
                            clicked => { root.header-field("bg_type", "color"); }
                        }
                        Button {
                            text: "Image";
                            height: 28px;
                            primary: root.bg-type == "image";
                            clicked => { root.pick-bg-image(); }
                        }
                    }
                }

                if root.bg-type == "color": VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: "BG R / G / B"; font-size: 10px; color: Theme.text-secondary; }
                    HorizontalLayout {
                        spacing: 4px;
                        BareSpinBox {
                            width: 96px;
                            horizontal-stretch: 0;
                            value: root.bg-r;
                            edited(v) => { root.header-field("bg_r", v); }
                        }
                        BareSpinBox {
                            width: 96px;
                            horizontal-stretch: 0;
                            value: root.bg-g;
                            edited(v) => { root.header-field("bg_g", v); }
                        }
                        BareSpinBox {
                            width: 96px;
                            horizontal-stretch: 0;
                            value: root.bg-b;
                            edited(v) => { root.header-field("bg_b", v); }
                        }
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                if root.status-message != "": VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: " "; font-size: 10px; }
                    Rectangle {
                        height: 28px;
                        background: root.status-is-error
                            ? #5a1f24
                            : #1e3a2a;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: root.status-is-error
                            ? #a23a3a
                            : #3aa05a;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            Text {
                                text: root.status-message;
                                font-size: 11px;
                                color: root.status-is-error
                                    ? #ffd0d0
                                    : #d0ffd0;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: " "; font-size: 10px; }
                    Button {
                        text: "Copy JSON";
                        height: 28px;
                        clicked => { root.copy-json-requested(); }
                    }
                }
                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: " "; font-size: 10px; }
                    Button {
                        text: "Close";
                        height: 28px;
                        clicked => { root.cancel(); }
                    }
                }
                VerticalLayout {
                    spacing: 2px;
                    alignment: end;
                    Text { text: " "; font-size: 10px; }
                    Button {
                        text: "Save";
                        height: 28px;
                        primary: true;
                        clicked => { root.save-requested(); }
                    }
                }
            }
        }

        HorizontalLayout {
            Rectangle {
                width: 220px;
                background: Theme.sidebar-background;
                border-width: 0px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;

                    Text { text: "Widgets"; font-size: 12px; font-weight: 700; color: Theme.text-primary; }

                    HorizontalLayout {
                        spacing: 4px;
                        ComboBox {
                            horizontal-stretch: 1;
                            model: root.widget-kind-labels;
                            current-index: 0;
                            selected(v) => { root.widget-added(v); }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 2px;
                            for w[i] in root.widgets: WidgetListRow {
                                widget: w;
                                index: i;
                                count: root.widgets.length;
                                selected: i == root.selected-index;
                                clicked(idx) => {
                                    root.selected-index = idx;
                                    root.widget-field(idx, "_select", "");
                                }
                                reorder(from, to) => { root.widget-reorder(from, to); }
                            }
                        }
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: #1a1f29;
                clip: true;

                property <length> pad: 24px;
                property <length> avail-w: self.width - 2 * self.pad;
                property <length> avail-h: self.height - 2 * self.pad;
                property <float> disp-aspect: root.base-width / root.base-height;
                property <length> canvas-w: min(self.avail-w, self.avail-h * self.disp-aspect);
                property <length> canvas-h: self.canvas-w / self.disp-aspect;
                property <length> canvas-x: (self.width - self.canvas-w) / 2;
                property <length> canvas-y: (self.height - self.canvas-h) / 2;

                Image {
                    x: parent.canvas-x;
                    y: parent.canvas-y;
                    width: parent.canvas-w;
                    height: parent.canvas-h;
                    source: root.preview-image;
                    image-fit: ImageFit.contain;
                }

                for w[idx] in root.widgets: WidgetBox {
                    widget: w;
                    index: idx;
                    selected: idx == root.selected-index;
                    canvas-x: parent.canvas-x;
                    canvas-y: parent.canvas-y;
                    canvas-w: parent.canvas-w;
                    canvas-h: parent.canvas-h;
                    base-w: root.base-width;
                    base-h: root.base-height;
                    selected-clicked(i) => { root.selected-index = i; root.widget-field(i, "_select", ""); }
                    moved(i, x, y) => { root.widget-moved(i, x, y); }
                }
            }

            PropertiesPanel {
                width: 554px;
                selected-index: root.selected-index;
                selected-widget: root.selected-widget;
                selected-ranges: root.selected-ranges;
                sensor-options: root.sensor-options;
                font-names: root.font-names;
                align-options: root.align-options;
                widget-field(i, f, v) => { root.widget-field(i, f, v); }
                range-field(i, f, v) => { root.range-field(i, f, v); }
                range-added => { root.range-added(); }
                range-removed(i) => { root.range-removed(i); }
                widget-removed(i) => { root.widget-removed(i); }
                pick-widget-image(i) => { root.pick-widget-image(i); }
            }
        }
    }
}
